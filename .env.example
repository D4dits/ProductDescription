# Wybierz dostawcę modelu: gemini, openai, z_ai, deepseek lub custom
LLM_PROVIDER=deepseek

# Klucze API (uzupełnij ten, który wybierzesz)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ZAI_API_KEY=your_zai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Z.AI działa przez endpoint zgodny z OpenAI SDK
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-5.2

# DeepSeek działa przez endpoint zgodny z OpenAI SDK
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Opcjonalna konfiguracja OpenAI-compatible dla innych dostawców
OPENAI_BASE_URL=
LLM_MODEL=

# Konfiguracja HTML opisów rozszerzonych
# Jeśli ustawione na true, generowany HTML będzie posiadał style inline i klasę .def pasujące do starszych wersji sklepu
USE_LEGACY_INLINE_STYLES=true

# Konfiguracja scrapingu i wyszukiwania
SCRAPE_PAGES_LIMIT=5
SCRAPE_TIMEOUT_SECONDS=10

# Ustawienia serwera FastAPI
HOST=127.0.0.1
PORT=8000
